{
  "name": "cursor-chat-copy",
  "displayName": "SuperSamuelCursor",
  "description": "Copy the current Cursor conversation and run a voice-to-clipboard workflow inside Cursor with live voice rewrite support.",
  "version": "0.2.0",
  "publisher": "marclelamy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marclelamy/SuperSamuel.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cursorChatCopy.copyCurrentConversation",
    "onCommand:cursorChatCopy.startVoiceCapture",
    "onCommand:cursorChatCopy.stopVoiceCapture",
    "onCommand:cursorChatCopy.setSinusoidApiKey",
    "onCommand:cursorChatCopy.setOpenRouterApiKey",
    "onCommand:cursorChatCopy.clearSavedApiKeys"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorChatCopy.copyCurrentConversation",
        "title": "Copy Current Cursor Conversation",
        "category": "SuperSamuelCursor"
      },
      {
        "command": "cursorChatCopy.startVoiceCapture",
        "title": "Start Voice Capture",
        "category": "SuperSamuelCursor",
        "icon": {
          "light": "media/icons/mic-light.svg",
          "dark": "media/icons/mic-dark.svg"
        }
      },
      {
        "command": "cursorChatCopy.stopVoiceCapture",
        "title": "Stop Voice Capture",
        "category": "SuperSamuelCursor",
        "icon": {
          "light": "media/icons/stop-light.svg",
          "dark": "media/icons/stop-dark.svg"
        }
      },
      {
        "command": "cursorChatCopy.showVoiceProcessing",
        "title": "Waiting For Voice Result",
        "category": "SuperSamuelCursor",
        "icon": {
          "light": "media/icons/process-light.svg",
          "dark": "media/icons/process-dark.svg"
        }
      },
      {
        "command": "cursorChatCopy.showVoiceDone",
        "title": "Voice Capture Complete",
        "category": "SuperSamuelCursor",
        "icon": {
          "light": "media/icons/done-light.svg",
          "dark": "media/icons/done-dark.svg"
        }
      },
      {
        "command": "cursorChatCopy.showVoiceError",
        "title": "Voice Capture Error",
        "category": "SuperSamuelCursor",
        "icon": {
          "light": "media/icons/error-light.svg",
          "dark": "media/icons/error-dark.svg"
        }
      },
      {
        "command": "cursorChatCopy.setSinusoidApiKey",
        "title": "Set SinusoidLabs API Key",
        "category": "SuperSamuelCursor"
      },
      {
        "command": "cursorChatCopy.setOpenRouterApiKey",
        "title": "Set OpenRouter API Key",
        "category": "SuperSamuelCursor"
      },
      {
        "command": "cursorChatCopy.clearSavedApiKeys",
        "title": "Clear Saved API Keys",
        "category": "SuperSamuelCursor"
      }
    ],
    "keybindings": [
      {
        "command": "cursorChatCopy.copyCurrentConversation",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "workbenchState != 'empty'"
      },
      {
        "command": "cursorChatCopy.startVoiceCapture",
        "key": "ctrl+alt+shift+r",
        "mac": "shift+alt+space",
        "when": "workbenchState != 'empty' && cursorVoice.phase == 'idle'"
      },
      {
        "command": "cursorChatCopy.stopVoiceCapture",
        "key": "ctrl+alt+shift+r",
        "mac": "shift+alt+space",
        "when": "workbenchState != 'empty' && cursorVoice.phase == 'recording'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cursorChatCopy.startVoiceCapture",
          "group": "navigation@100",
          "when": "resourceScheme == file && cursorVoice.phase == 'idle'"
        },
        {
          "command": "cursorChatCopy.stopVoiceCapture",
          "group": "navigation@100",
          "when": "resourceScheme == file && cursorVoice.phase == 'recording'"
        },
        {
          "command": "cursorChatCopy.showVoiceProcessing",
          "group": "navigation@100",
          "when": "resourceScheme == file && (cursorVoice.phase == 'transcribing' || cursorVoice.phase == 'cleanup')"
        },
        {
          "command": "cursorChatCopy.showVoiceDone",
          "group": "navigation@100",
          "when": "resourceScheme == file && cursorVoice.phase == 'done'"
        },
        {
          "command": "cursorChatCopy.showVoiceError",
          "group": "navigation@100",
          "when": "resourceScheme == file && cursorVoice.phase == 'error'"
        }
      ]
    },
    "configuration": {
      "title": "SuperSamuelCursor",
      "properties": {
        "superSamuelCursor.ffmpegPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the ffmpeg binary used for microphone recording."
        },
        "superSamuelCursor.sinusoidModel": {
          "type": "string",
          "default": "spark",
          "description": "SinusoidLabs STT model to use for voice transcription."
        },
        "superSamuelCursor.openRouterModel": {
          "type": "string",
          "default": "qwen/qwen3-32b",
          "description": "OpenRouter model used to rewrite the raw transcript against the current chat context."
        },
        "superSamuelCursor.openRouterTemperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature used for the single OpenRouter rewrite request."
        },
        "superSamuelCursor.openRouterBaseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1/chat/completions",
          "description": "OpenRouter chat completions endpoint."
        },
        "superSamuelCursor.rewriteInstruction": {
          "type": "string",
          "default": "Rewrite the raw transcript into clean written dictation while preserving all meaning and technical details. Remove filler words such as um, uh, like when used as filler, you know, repeated words, false starts, self-corrections, stutters, and speech artifacts. Keep the same intent, facts, uncertainty, and level of detail. Do not summarize, shorten for brevity, add new facts, or pull in content from the chat context except to fix an obviously misrecognized technical term, code symbol, product name, or proper noun. Return only the cleaned transcript.",
          "description": "Additional instructions appended to the OpenRouter rewrite prompt."
        },
        "superSamuelCursor.contextMaxChars": {
          "type": "number",
          "default": -1,
          "minimum": -1,
          "description": "How many trailing characters of the active Cursor conversation to send as rewrite context. Use -1 for all, or 0 for none."
        },
        "superSamuelCursor.finalizationTailMs": {
          "type": "number",
          "default": 1800,
          "minimum": 300,
          "description": "Advanced. Extra quiet-window wait before returning the best available transcript after recording stops."
        }
      }
    }
  },
  "scripts": {
    "check": "node --check extension.js && node --check lib/paths.js && node --check lib/sqlite.js && node --check lib/cursorConversation.js && node --check lib/format.js && node --check lib/state.js && node --check lib/secrets.js && node --check lib/prompt.js && node --check lib/openrouter.js && node --check lib/ffmpegRecorder.js && node --check lib/sinusoid.js && node --check lib/logging.js"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
